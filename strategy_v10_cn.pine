//@version=6
strategy("CN-急涨急跌吸筹策略 v10 (形态质量过滤)",
    overlay=true,
    initial_capital=100000,
    pyramiding=0,
    default_qty_type=strategy.percent_of_equity,
    default_qty_value=90,
    commission_type=strategy.commission.percent,
    commission_value=0.2,
    calc_on_every_tick=true,
    close_entries_rule="ANY")

//================ 参数 =================
pumpPct         = input.float(2.0,  "急拉阈值%")
// v10: 急跌阈值从1%提高到1.5%，要求更明显的吸筹形态
dumpPct         = input.float(1.5,  "急跌阈值%")
windowBars      = input.int(30,     "形态检测窗口(bars)")
minPatternCount = input.int(1,      "最少形态次数")

// v10: 恢复v8的止盈参数，5%/10%盈亏比更合理
takeProfit1     = input.float(5.0,  "止盈1%")
takeProfit2     = input.float(10.0, "止盈2%")
stopLossPct     = input.float(4.0,  "止损%")

confirmMA       = input.int(5,      "入场确认均线周期")

// 26周低位过滤
lowPositionPct  = input.float(80.0, "26周低位阈值%")

// 5日波动过滤
max5dVolatility = input.float(25.0, "5日最大波动%")

// 回测结束日期
endYear  = input.int(2026, "结束年份")
endMonth = input.int(4,    "结束月份")
endDay   = input.int(19,   "结束日期")

//================ 指标 =================
ma5  = ta.sma(close, confirmMA)
ma20 = ta.sma(close, 20)

//================ 日线数据 =================
dailyClose = request.security(syminfo.tickerid, "D", close)
dailyMA10  = request.security(syminfo.tickerid, "D", ta.sma(close, 10))
dailyMA20  = request.security(syminfo.tickerid, "D", ta.sma(close, 20))

// 横盘或上升趋势均可
dailySideways = math.abs(dailyClose - dailyMA20) / dailyMA20 < 0.03 and math.abs(dailyMA10 - dailyMA20) / dailyMA20 < 0.02
dailyUptrend  = dailyClose > dailyMA20 and dailyMA10 > dailyMA20
dailyTrendOK  = dailySideways or dailyUptrend

//================ 26周低位过滤 =================
weeklyHigh26     = request.security(syminfo.tickerid, "D", ta.highest(high, 130))
weeklyLow26      = request.security(syminfo.tickerid, "D", ta.lowest(low,  130))
pricePosition26w = (dailyClose - weeklyLow26) / (weeklyHigh26 - weeklyLow26) * 100
isLowPosition    = pricePosition26w < lowPositionPct

//================ 5日波动过滤 =================
dailyHigh5   = request.security(syminfo.tickerid, "D", ta.highest(high, 5))
dailyLow5    = request.security(syminfo.tickerid, "D", ta.lowest(low,  5))
volatility5d = (dailyHigh5 - dailyLow5) / dailyLow5 * 100
lowVolatility = volatility5d < max5dVolatility

//================ 时间过滤 =================
timeInMinutes   = hour * 60 + minute
isAfterOpenHour = timeInMinutes >= 10 * 60 + 30

//================ 急拉急跌形态 =================
hh = ta.highest(high, windowBars)
ll = ta.lowest(low,  windowBars)

rise = (hh - ll) / ll * 100
fall = (hh - close) / hh * 100

hhIdx = ta.highestbars(high, windowBars)
llIdx = ta.lowestbars(low,  windowBars)

isPattern  = rise > pumpPct and fall > dumpPct and fall < rise * 0.6 and llIdx < hhIdx and isAfterOpenHour
newPattern = isPattern and not isPattern[1]

//================ 形态计数 =================
var float patternCounter = 0.0
if newPattern
    patternCounter := patternCounter + 1
hasEnoughPatterns = patternCounter >= minPatternCount
patternCount = patternCounter

//================ 趋势过滤（分钟线） =================
trendOK    = close > ma20
allTrendOK = trendOK and dailyTrendOK

//================ 入场确认：必须站上ma5 =================
priceAboveConfirmMA = close > ma5

//================ T+1 控制 =================
var int entryYear  = na
var int entryMonth = na
var int entryDay   = na

isDifferentDay = strategy.position_size > 0 and not na(entryDay) and
     (year != entryYear or month != entryMonth or dayofmonth != entryDay)
canSell = isDifferentDay

if strategy.position_size == 0 and strategy.position_size[1] > 0
    entryYear  := na
    entryMonth := na
    entryDay   := na

//================ 买点 =================
isEndDate = year == endYear and month == endMonth and dayofmonth == endDay
buySignal = newPattern and hasEnoughPatterns and allTrendOK and isLowPosition and lowVolatility and priceAboveConfirmMA and strategy.position_size == 0 and not isEndDate

//================ 盈亏计算 =================
entryPrice = strategy.position_avg_price
profitPct  = strategy.position_size > 0 ? (close - entryPrice) / entryPrice * 100 : 0.0

var float peakProfit = 0.0
if strategy.position_size > 0
    peakProfit := math.max(peakProfit, profitPct)
if strategy.position_size == 0
    peakProfit := 0.0

//================ 止损价格 =================
stopPrice = entryPrice * (1 - stopLossPct / 100)

//================ 出场条件 =================
tp1 = profitPct >= takeProfit1 and canSell
tp2 = profitPct >= takeProfit2 and canSell
sl  = close < stopPrice and canSell

trailStop = canSell and peakProfit >= takeProfit1 and (peakProfit - profitPct) >= 3.0

//================ 执行 =================
if buySignal
    strategy.entry("BUY", strategy.long)
    entryYear  := year
    entryMonth := month
    entryDay   := dayofmonth
    patternCounter := 0
    alert(
        '{"symbol":"' + syminfo.ticker + '","action":"ENTRY"' +
        ',"entry":' + str.tostring(close) +
        ',"stop":' + str.tostring(close * (1 - stopLossPct/100)) +
        ',"tp1":' + str.tostring(close * (1 + takeProfit1/100)) +
        ',"tp2":' + str.tostring(close * (1 + takeProfit2/100)) + '}',
        alert.freq_once_per_bar_close)

if tp1 and not tp2 and not trailStop
    strategy.close("BUY", qty_percent=50, comment="TP1")
    alert('{"symbol":"' + syminfo.ticker + '","action":"EXIT","reason":"TP1","profit_pct":' + str.tostring(profitPct) + '}', alert.freq_once_per_bar_close)

if tp2
    strategy.close("BUY", comment="TP2")
    alert('{"symbol":"' + syminfo.ticker + '","action":"EXIT","reason":"TP2","profit_pct":' + str.tostring(profitPct) + '}', alert.freq_once_per_bar_close)

if sl and not tp1
    strategy.close("BUY", comment="SL")
    alert('{"symbol":"' + syminfo.ticker + '","action":"EXIT","reason":"STOP_LOSS","profit_pct":' + str.tostring(profitPct) + '}', alert.freq_once_per_bar_close)

if trailStop and not tp2
    strategy.close("BUY", comment="追踪止盈")
    alert('{"symbol":"' + syminfo.ticker + '","action":"EXIT","reason":"TRAIL_STOP","profit_pct":' + str.tostring(profitPct) + '}', alert.freq_once_per_bar_close)

//================ 图表 =================
plot(ma5,  color=color.purple, linewidth=1, title="MA5(确认)")
plot(ma20, color=color.blue,   linewidth=2, title="MA20")
plot(strategy.position_size > 0 ? stopPrice : na,
     color=color.red, style=plot.style_linebr, linewidth=1, title="止损线")

plotshape(newPattern, location=location.belowbar, color=color.orange,
     style=shape.triangleup, size=size.small, text="形态")
plotshape(buySignal, location=location.belowbar, color=color.green,
     style=shape.labelup, size=size.normal, text="买")
bgcolor(isPattern ? color.new(color.yellow, 92) : na)
bgcolor(strategy.position_size > 0 and not canSell ? color.new(color.red, 90) : na)

//================ 面板 =================
var table tb = table.new(position.top_right, 2, 14, bgcolor=color.new(color.gray, 80))
if barstate.islast
    table.cell(tb, 0, 0,  "涨幅%",      text_color=color.white)
    table.cell(tb, 1, 0,  str.tostring(rise, "#.##"),             text_color=rise > pumpPct ? color.green : color.red)
    table.cell(tb, 0, 1,  "跌幅%",      text_color=color.white)
    table.cell(tb, 1, 1,  str.tostring(fall, "#.##"),             text_color=fall > dumpPct ? color.green : color.red)
    table.cell(tb, 0, 2,  "形态计数",   text_color=color.white)
    table.cell(tb, 1, 2,  str.tostring(patternCount, "#"),        text_color=patternCount >= minPatternCount ? color.green : color.red)
    table.cell(tb, 0, 3,  "日线趋势",   text_color=color.white)
    table.cell(tb, 1, 3,  dailyUptrend ? "上升" : (dailySideways ? "横盘" : "下降"), text_color=dailyTrendOK ? color.green : color.red)
    table.cell(tb, 0, 4,  "26周位置%",  text_color=color.white)
    table.cell(tb, 1, 4,  str.tostring(pricePosition26w, "#.##"), text_color=isLowPosition ? color.green : color.red)
    table.cell(tb, 0, 5,  "5日波动%",   text_color=color.white)
    table.cell(tb, 1, 5,  str.tostring(volatility5d, "#.##"),     text_color=lowVolatility ? color.green : color.red)
    table.cell(tb, 0, 6,  "确认均线",   text_color=color.white)
    table.cell(tb, 1, 6,  priceAboveConfirmMA ? "站上✓" : "未站上✗", text_color=priceAboveConfirmMA ? color.green : color.red)
    table.cell(tb, 0, 7,  "峰值盈利%",  text_color=color.white)
    table.cell(tb, 1, 7,  str.tostring(peakProfit, "#.##"),       text_color=peakProfit > 0 ? color.green : color.gray)
    table.cell(tb, 0, 8,  "入场日",     text_color=color.white)
    table.cell(tb, 1, 8,  na(entryDay) ? "-" : str.tostring(entryMonth) + "/" + str.tostring(entryDay), text_color=color.yellow)
    table.cell(tb, 0, 9,  "可卖出",     text_color=color.white)
    table.cell(tb, 1, 9,  canSell ? "是" : "否(T+1)",             text_color=canSell ? color.green : color.red)
    table.cell(tb, 0, 10, "盈亏%",      text_color=color.white)
    table.cell(tb, 1, 10, str.tostring(profitPct, "#.##"),        text_color=profitPct >= 0 ? color.green : color.red)
    table.cell(tb, 0, 11, "交易数",     text_color=color.white)
    table.cell(tb, 1, 11, str.tostring(strategy.closedtrades),    text_color=color.yellow)
    table.cell(tb, 0, 12, "胜率",       text_color=color.white)
    wr = strategy.closedtrades > 0 ? strategy.wintrades / strategy.closedtrades * 100 : 0
    table.cell(tb, 1, 12, str.tostring(wr, "#") + "%",            text_color=wr >= 50 ? color.green : color.red)
    table.cell(tb, 0, 13, "净利润",     text_color=color.white)
    table.cell(tb, 1, 13, str.tostring(strategy.netprofit, "#"),  text_color=strategy.netprofit >= 0 ? color.green : color.red)
