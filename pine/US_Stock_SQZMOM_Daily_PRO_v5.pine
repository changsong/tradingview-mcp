//@version=6
strategy(
     "US Stock SQZMOM Daily PRO v5 (Multi-Filter)",
     overlay=true,
     initial_capital=100000,
     pyramiding=0,
     default_qty_type=strategy.fixed,
     commission_type=strategy.commission.percent,
     commission_value=0.05,
     calc_on_every_tick=false,
     process_orders_on_close=false)

//==================================================
// 参数
//==================================================
bbLen    = input.int(20, "BB Length")
bbMult   = input.float(2.0)
kcLen    = input.int(20, "KC Length")
kcMult   = input.float(1.5)

emaFast  = input.int(60,  "Trend EMA (60)")
emaSlow  = input.int(200, "Market EMA (200)")

riskPct  = input.float(1.0, "Risk %")
minScore = input.int(70, "Min Score")   // v5: 从65提高到70

atrLen   = input.int(14, "ATR Length")
atrMult  = input.float(2.0, "ATR Stop Mult")      // v5: 2.5→2.0，减少止损距离

slipATRmult     = input.float(0.1, "ATR Slippage")
cooldownBars    = input.int(3,  "Cooldown Bars")
minSqzBars      = input.int(4,  "Min SQZ Bars")   // v5: 3→4
maxSqzBars      = input.int(8,  "Max SQZ Bars")   // v5: 10→8，过滤久的横盘

// v5: TP距离调整，让利润奔跑
tp1Mult         = input.float(2.0, "TP1 ATR Mult")   // v5: 1R→2R
tp2Mult         = input.float(3.5, "TP2 ATR Mult")   // v5: 2R→3.5R
atrMultAfterTP1 = input.float(1.5, "ATR Trail After TP1")  // v5: 1.2→1.5

// v5: RSI过滤
rsiLen          = input.int(14, "RSI Length")
rsiOverbought   = input.int(72, "RSI Overbought")  // v5新增：超买过滤

// v5: 突破确认
breakoutBars    = input.int(10, "Breakout Lookback")  // v5新增：N日高点突破

//==================================================
// SQZMOM
//==================================================
f_sqz(src) =>
    basis    = ta.sma(src, bbLen)
    dev      = bbMult * ta.stdev(src, bbLen)
    upperBB  = basis + dev
    lowerBB  = basis - dev
    ma       = ta.sma(src, kcLen)
    kcATR    = ta.atr(kcLen)
    upperKC  = ma + kcATR * kcMult
    lowerKC  = ma - kcATR * kcMult
    sqzOff   = (upperBB - lowerBB) < ((upperKC - lowerKC) * 0.8)
    mid      = (ta.highest(high, kcLen) + ta.lowest(low, kcLen)) / 2
    val      = ta.linreg(src - mid, kcLen, 0)
    [sqzOff, val]

[sqz, val] = f_sqz(close)

//==================================================
// SQZMOM val 斜率确认 (v5新增)
//==================================================
valSlope    = val - val[2]          // 2bar加速度
valAccel    = valSlope > 0 and val > 0  // 正向且加速

//==================================================
// 压缩计数
//==================================================
var int sqzCount = 0
if sqz
    sqzCount += 1
else
    sqzCount := 0

validCompression = sqzCount >= minSqzBars and sqzCount <= maxSqzBars

//==================================================
// 趋势结构
//==================================================
ema20  = ta.ema(close, 20)
ema60  = ta.ema(close, emaFast)
ema200 = ta.ema(close, emaSlow)

trendUp =
     ema20  > ema60  and
     ema60  > ema200 and
     close  > ema20

// v5: EMA20上升确认（EMA20斜率为正）
ema20Rising = ema20 > ema20[3]

//==================================================
// RSI 过滤 (v5新增)
//==================================================
rsi        = ta.rsi(close, rsiLen)
rsiOK      = rsi < rsiOverbought    // 非超买才入场

//==================================================
// 突破确认 (v5新增)：收盘价突破N日前高
//==================================================
hhvBreak   = close > ta.highest(high, breakoutBars)[1]

//==================================================
// 成交量
//==================================================
volumeMA20      = ta.sma(volume, 20)
volOK_primary   = volume > volumeMA20 * 1.0
vol20High       = ta.highest(volume, 20)
volOK_secondary = (volume > vol20High * 0.5) and sqz and trendUp
volOK           = volOK_primary or volOK_secondary
minLiquidity    = volumeMA20 > 100000

vol5            = ta.sma(volume, 5)
volMomentum     = vol5 > volumeMA20   // 5日成交量均值高于20日

//==================================================
// 风控过滤
//==================================================
bigGap        = (close - close[1]) / close[1] > 0.15
bigMove       = (close - ta.lowest(close, 5)) / ta.lowest(close, 5) > 0.25
notOverExtended = not bigMove and not bigGap

volMA20       = ta.sma(volume, 20)
hhv5          = ta.highest(high, 5)
fakeBreak     = high > hhv5[1] and close < open and volume > volMA20 and (high - close) / (high - low + 0.0001) > 0.6

validStock    = notOverExtended and minLiquidity

//==================================================
// 评分 (v5重构)
//==================================================
score = 0
score += sqz and val > 0 ? 25 : 0           // SQZMOM压缩 + 正向
score += valAccel ? 20 : 0                  // v5新增：momentum加速 (重要)
score += validCompression ? 10 : 0          // 压缩时长合理
score += hhvBreak ? 15 : 0                  // v5新增：突破N日前高 (重要)
score += volOK ? 10 : 0                     // 成交量
score += trendUp ? 10 : 0                   // 趋势对齐
score += not fakeBreak ? 10 : 0             // 非假突破

canTrade = score >= minScore

//==================================================
// ATR + 仓位
//==================================================
atr      = ta.atr(atrLen)
slippage = atr * slipATRmult
stopDist = atr * atrMult
risk     = strategy.equity * riskPct / 100
qty      = math.max(1, math.floor(risk / stopDist))

//==================================================
// 状态变量
//==================================================
var float entryPrice        = na
var float tp1Price          = na
var float tp2Price          = na
var float highestSinceEntry = na
var bool  tookTP1           = false
var string exitReason       = ""
var bool  inPosition        = false
var int   barsSinceExit     = 0

//==================================================
// 入场条件 (v5强化)
//==================================================
longCond =
     trendUp            and
     ema20Rising        and   // v5新增：EMA20斜率为正
     canTrade           and
     validCompression   and
     not fakeBreak      and
     validStock         and
     volMomentum        and
     rsiOK              and   // v5新增：RSI未超买
     hhvBreak           and   // v5新增：突破N日前高
     barstate.isconfirmed and
     barsSinceExit >= cooldownBars and
     strategy.position_size == 0

//==================================================
// ATR Trailing
//==================================================
if strategy.position_size > 0
    highestSinceEntry := na(highestSinceEntry) ? high : math.max(highestSinceEntry, high)
else
    highestSinceEntry := na
    barsSinceExit += 1

float curAtrMult    = tookTP1 ? atrMultAfterTP1 : atrMult
atrTrailStop_raw    = highestSinceEntry - atr * curAtrMult
safeStop            = na(atrTrailStop_raw) ? entryPrice - stopDist : atrTrailStop_raw

//==================================================
// 入场执行
//==================================================
if longCond
    entryPrice        := close + slippage
    tp1Price          := entryPrice + stopDist * tp1Mult   // v5: 2R
    tp2Price          := entryPrice + stopDist * tp2Mult   // v5: 3.5R
    highestSinceEntry := high
    tookTP1           := false
    exitReason        := ""
    inPosition        := true
    barsSinceExit     := 0
    strategy.entry("LONG", strategy.long, qty)

//==================================================
// 持仓管理 (v5: EMA20止损改为更宽松条件)
//==================================================
if strategy.position_size > 0
    highestSinceEntry := math.max(highestSinceEntry, high)
    atrTrailRaw = highestSinceEntry - atr * (tookTP1 ? atrMultAfterTP1 : atrMult)

    if not tookTP1 and high >= tp1Price
        tookTP1 := true
        strategy.close("LONG", "TP1", qty_percent = 50)

    // v5: EMA20止损更严格：要求连续2根K线低于EMA20且EMA20下行
    ema20Falling   = ema20 < ema20[1] and ema20 < ema20[3]
    belowEma20x2   = close < ema20 and close[1] < ema20[1]
    ema20StopCond  = belowEma20x2 and ema20Falling

    if exitReason == ""
        if close <= safeStop
            exitReason := "ATR"
        else if ema20StopCond
            exitReason := "EMA20"
        else if high >= tp2Price
            exitReason := "TP2"

    if exitReason != ""
        strategy.close("LONG", exitReason)
        inPosition := false

//==================================================
// 图形
//==================================================
plot(safeStop, "ATR Trail", color=color.yellow, linewidth=1)
plot(ema20,    "EMA20",     color=color.red,    linewidth=1)
plot(ema60,    "EMA60",     color=color.blue,   linewidth=1)

plotchar(score, "Score", "⭐", location.top)

// RSI bar color hint
barcolor(rsi > rsiOverbought ? color.new(color.red, 60) : na)

string p1 = "trendUp:" + str.tostring(trendUp) + " EMA20↑:" + str.tostring(ema20Rising) + " SQZ:" + str.tostring(sqz)
string p2 = "valAccel:" + str.tostring(valAccel) + " hhvBreak:" + str.tostring(hhvBreak) + " RSI:" + str.tostring(math.round(rsi))
string p3 = "volMom:" + str.tostring(volMomentum) + " validComp:" + str.tostring(validCompression) + " fakeBreak:" + str.tostring(fakeBreak)
string st_txt = p1 + " | " + p2 + " | " + p3 + " | Score:" + str.tostring(score) + (score >= minScore ? " 🟢LONG" : " 🔴WAIT")

color statusColor = score >= minScore ? color.green : color.red
var table panel = table.new(position.top_right, 1, 1)
table.cell(panel, 0, 0, st_txt, bgcolor=statusColor, text_color=color.white, text_size=size.small)
