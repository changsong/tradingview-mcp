//@version=6
strategy(
     "US Stock SQZMOM Daily PRO v14 (Val Freshness)",
     overlay=true,
     initial_capital=100000,
     pyramiding=0,
     default_qty_type=strategy.fixed,
     commission_type=strategy.commission.percent,
     commission_value=0.05,
     calc_on_every_tick=false,
     process_orders_on_close=false)

//==================================================
// 参数
//==================================================
bbLen    = input.int(20, "BB Length")
bbMult   = input.float(2.0)
kcLen    = input.int(20, "KC Length")
kcMult   = input.float(1.5)

emaFast  = input.int(60,  "Trend EMA")
emaSlow  = input.int(200, "Market EMA")

riskPct  = input.float(1.0, "Risk %")
minScore = input.int(65, "Min Score")

atrLen   = input.int(14, "ATR Length")
atrMult  = input.float(2.0, "ATR Stop Mult")

slipATRmult     = input.float(0.1, "ATR Slippage")
cooldownBars    = input.int(3,  "Cooldown Bars")
minSqzBars      = input.int(5,  "Min SQZ Bars")
maxSqzBars      = input.int(8,  "Max SQZ Bars")

tp1Mult         = input.float(2.0, "TP1 ATR Mult")
tp2Mult         = input.float(3.5, "TP2 ATR Mult")
atrMultAfterTP1 = input.float(1.5, "ATR Trail After TP1")

rsiLen          = input.int(14, "RSI Length")
rsiOverbought   = input.int(75, "RSI Overbought")

breakoutBars    = input.int(5, "Breakout Lookback")

maxLossPct      = input.float(6.0, "Max Loss %")

// v14: val新高回看
// 要求val必须是过去N根K线的最高值
// 比valAccel(仅需val>val[2])更严格：需要val处于近期高峰
// 过滤val正在高位横盘或回落的入场（动量衰竭）
valFreshBars    = input.int(5, "Val Freshness Bars")

//==================================================
// SQZMOM
//==================================================
f_sqz(src) =>
    basis    = ta.sma(src, bbLen)
    dev      = bbMult * ta.stdev(src, bbLen)
    upperBB  = basis + dev
    lowerBB  = basis - dev
    ma       = ta.sma(src, kcLen)
    kcATR    = ta.atr(kcLen)
    upperKC  = ma + kcATR * kcMult
    lowerKC  = ma - kcATR * kcMult
    sqzOff   = (upperBB - lowerBB) < ((upperKC - lowerKC) * 0.8)
    mid      = (ta.highest(high, kcLen) + ta.lowest(low, kcLen)) / 2
    val      = ta.linreg(src - mid, kcLen, 0)
    [sqzOff, val]

[sqz, val] = f_sqz(close)

valSlope = val - val[2]
valAccel = valSlope > 0 and val > 0

//==================================================
// v14: val新高过滤
// val必须高于过去N根K线的最高val
// 即动量读数正处于近期高峰，而非已见顶回落
// 比valAccel更严格：要求val持续创新高，排除val高位震荡的情形
//==================================================
valFresh = val > ta.highest(val, valFreshBars)[1] and val > 0

//==================================================
// 压缩计数
//==================================================
var int sqzCount = 0
if sqz
    sqzCount += 1
else
    sqzCount := 0

validCompression = sqzCount >= minSqzBars and sqzCount <= maxSqzBars

//==================================================
// 趋势
//==================================================
ema20  = ta.ema(close, 20)
ema60  = ta.ema(close, emaFast)
ema200 = ta.ema(close, emaSlow)

trendUp =
     ema20  > ema60  and
     ema60  > ema200 and
     close  > ema20

ema20Rising = ema20 > ema20[3]

//==================================================
// RSI 过滤
//==================================================
rsi   = ta.rsi(close, rsiLen)
rsiOK = rsi < rsiOverbought

//==================================================
// 突破确认
//==================================================
hhvBreak = close > ta.highest(high, breakoutBars)[1]

//==================================================
// 成交量
//==================================================
volumeMA20      = ta.sma(volume, 20)
volOK_primary   = volume > volumeMA20 * 1.0
vol20High       = ta.highest(volume, 20)
volOK_secondary = (volume > vol20High * 0.5) and sqz and trendUp
volOK           = volOK_primary or volOK_secondary
minLiquidity    = volumeMA20 > 100000
vol5            = ta.sma(volume, 5)
volMomentum     = vol5 > volumeMA20

//==================================================
// 风控过滤
//==================================================
bigGap          = (close - close[1]) / close[1] > 0.15
bigMove         = (close - ta.lowest(close, 5)) / ta.lowest(close, 5) > 0.25
notOverExtended = not bigMove and not bigGap
volMA20         = ta.sma(volume, 20)
hhv5            = ta.highest(high, 5)
fakeBreak       = high > hhv5[1] and close < open and volume > volMA20 and (high - close) / (high - low + 0.0001) > 0.6
validStock      = notOverExtended and minLiquidity

//==================================================
// 评分 v14（同v7）
//==================================================
score = 0
score += sqz and val > 0 ? 25 : 0
score += valAccel ? 15 : 0
score += hhvBreak ? 10 : 0
score += validCompression ? 10 : 0
score += volOK ? 10 : 0
score += trendUp ? 10 : 0
score += not fakeBreak ? 10 : 0
score += ema20Rising ? 10 : 0

canTrade = score >= minScore

//==================================================
// ATR + 仓位
//==================================================
atr      = ta.atr(atrLen)
slippage = atr * slipATRmult
stopDist = atr * atrMult
risk     = strategy.equity * riskPct / 100
qty      = math.max(1, math.floor(risk / stopDist))

//==================================================
// 状态变量
//==================================================
var float entryPrice        = na
var float tp1Price          = na
var float tp2Price          = na
var float maxLossPrice      = na
var float highestSinceEntry = na
var bool  tookTP1           = false
var string exitReason       = ""
var bool  inPosition        = false
var int   barsSinceExit     = 0

//==================================================
// 入场条件 v14
// v14改变：
//   - 在v7基础上（valAccel硬性、minSqzBars=5、MaxLoss=6%）
//   - 将 valAccel 替换为 valFresh：
//     val必须是过去valFreshBars根K线的最高值（默认5）
//     比valAccel更严格，要求动量处于近期峰值而非高位震荡
//     目标：过滤动量已经见顶但尚未反转时的弱势入场
//==================================================
longCond =
     trendUp            and
     ema20Rising        and
     valFresh           and   // v14: 替换valAccel，要求val处于近期新高
     canTrade           and
     validCompression   and
     not fakeBreak      and
     validStock         and
     volMomentum        and
     rsiOK              and
     barstate.isconfirmed and
     barsSinceExit >= cooldownBars and
     strategy.position_size == 0

//==================================================
// ATR Trailing
//==================================================
if strategy.position_size > 0
    highestSinceEntry := na(highestSinceEntry) ? high : math.max(highestSinceEntry, high)
else
    highestSinceEntry := na
    barsSinceExit += 1

float curAtrMult = tookTP1 ? atrMultAfterTP1 : atrMult
atrTrailStop_raw = highestSinceEntry - atr * curAtrMult
safeStop         = na(atrTrailStop_raw) ? entryPrice - stopDist : atrTrailStop_raw

//==================================================
// 入场执行
//==================================================
if longCond
    entryPrice        := close + slippage
    tp1Price          := entryPrice + stopDist * tp1Mult
    tp2Price          := entryPrice + stopDist * tp2Mult
    maxLossPrice      := entryPrice * (1.0 - maxLossPct / 100.0)
    highestSinceEntry := high
    tookTP1           := false
    exitReason        := ""
    inPosition        := true
    barsSinceExit     := 0
    strategy.entry("LONG", strategy.long, qty)

//==================================================
// 持仓管理 v14
//==================================================
if strategy.position_size > 0
    highestSinceEntry := math.max(highestSinceEntry, high)

    if not tookTP1 and high >= tp1Price
        tookTP1 := true
        strategy.close("LONG", "TP1", qty_percent = 50)

    ema20Falling  = ema20 < ema20[1] and ema20 < ema20[3]
    belowEma20x2  = close < ema20 and close[1] < ema20[1]
    ema20StopCond = belowEma20x2 and ema20Falling

    if exitReason == ""
        if not na(maxLossPrice) and close <= maxLossPrice
            exitReason := "MaxLoss"
        else if close <= safeStop
            exitReason := "ATR"
        else if ema20StopCond
            exitReason := "EMA20"
        else if high >= tp2Price
            exitReason := "TP2"

    if exitReason != ""
        strategy.close("LONG", exitReason)
        inPosition := false

//==================================================
// 图形
//==================================================
plot(safeStop, "ATR Trail", color=color.yellow, linewidth=1)
plot(not na(maxLossPrice) and strategy.position_size > 0 ? maxLossPrice : na, "MaxLoss", color=color.orange, linewidth=1, style=plot.style_circles)
plot(ema20,    "EMA20",     color=color.red,    linewidth=1)
plot(ema60,    "EMA60",     color=color.blue,   linewidth=1)

plotchar(score, "Score", "⭐", location.top)
barcolor(rsi > rsiOverbought ? color.new(color.red, 60) : na)

string p1 = "trendUp:" + str.tostring(trendUp) + " EMA20↑:" + str.tostring(ema20Rising) + " valFresh:" + str.tostring(valFresh)
string p2 = "valAccel:" + str.tostring(valAccel) + " RSI:" + str.tostring(math.round(rsi)) + " validComp:" + str.tostring(validCompression)
string st_txt = p1 + " | " + p2 + " | Score:" + str.tostring(score) + (canTrade and trendUp and ema20Rising and valFresh ? " 🟢LONG" : " 🔴WAIT")
color statusColor = canTrade and trendUp and ema20Rising and valFresh ? color.green : color.red
var table panel = table.new(position.top_right, 1, 1)
table.cell(panel, 0, 0, st_txt, bgcolor=statusColor, text_color=color.white, text_size=size.small)
