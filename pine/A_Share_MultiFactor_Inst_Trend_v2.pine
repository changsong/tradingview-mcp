//@version=6
strategy("A股 多因子机构趋势策略 v2",
     overlay=true,
     initial_capital=100000,
     pyramiding=0,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     commission_type=strategy.commission.percent,
     commission_value=0.03,
     calc_on_every_tick=false,
     process_orders_on_close=true)

//====================================================
// 参数
//====================================================
rsPeriod      = input.int(20,  "RS周期")
rsThreshold   = input.float(1.05, "RS阈值")

rvolPeriod    = input.int(20,  "RVOL周期")
rvolThreshold = input.float(1.3,  "RVOL阈值")

betaPeriod    = input.int(60,  "Beta周期")
betaThreshold = input.float(1.0,  "Beta阈值")

anchorLen     = input.int(30,  "AVWAP锚定周期")

vpLookback    = input.int(60,  "筹码观察周期")

atrLen        = input.int(14,  "ATR周期")
atrStopMult   = input.float(2.0,"ATR止损倍数")

benchmark = input.symbol("SSE:000300", "基准指数")

useRS      = input.bool(true, "启用 RS 过滤")
useRVOL    = input.bool(true, "启用 RVOL 过滤")
useBeta    = input.bool(true, "启用 Beta 过滤")
useAVWAP   = input.bool(true, "启用 AVWAP 过滤")
usePOC     = input.bool(true, "启用 POC 过滤")
useMarket  = input.bool(true, "启用大盘多头过滤")

//====================================================
// 基准
//====================================================
indexClose = request.security(benchmark, timeframe.period, close, lookahead=barmerge.lookahead_off)

//====================================================
// RS
//====================================================
stockReturn = close / close[rsPeriod]
indexReturn = indexClose / indexClose[rsPeriod]
rs = stockReturn / indexReturn
rsStrong = not useRS or rs > rsThreshold

//====================================================
// RVOL
//====================================================
volMA = ta.sma(volume, rvolPeriod)
rvol = volume / volMA
rvolStrong = not useRVOL or rvol > rvolThreshold

//====================================================
// Beta
//====================================================
stockRet  = math.log(close / nz(close[1], close))
indexRet  = math.log(indexClose / nz(indexClose[1], indexClose))
corr      = ta.correlation(stockRet, indexRet, betaPeriod)
stockStd  = ta.stdev(stockRet, betaPeriod)
marketStd = ta.stdev(indexRet, betaPeriod)
beta      = corr * (stockStd / marketStd)
betaStrong = not useBeta or beta > betaThreshold

//====================================================
// Anchored VWAP (修复初始化)
//====================================================
anchorHigh = ta.highest(high, anchorLen)
newAnchor  = high >= anchorHigh

var float cumulativePV = 0.0
var float cumulativeV  = 0.0

if newAnchor
    cumulativePV := hlc3 * volume
    cumulativeV  := volume
else
    cumulativePV += hlc3 * volume
    cumulativeV  += volume

avwap = cumulativeV > 0 ? cumulativePV / cumulativeV : close
aboveAVWAP = not useAVWAP or close > avwap

//====================================================
// POC 近似
//====================================================
poc = ta.vwma(close, vpLookback)
abovePOC = not usePOC or close > poc

//====================================================
// 市场环境
//====================================================
marketMA20 = request.security(benchmark, timeframe.period, ta.sma(close, 20), lookahead=barmerge.lookahead_off)
marketBull = not useMarket or indexClose > marketMA20

//====================================================
// 入场
//====================================================
longCondition = rsStrong and rvolStrong and betaStrong and aboveAVWAP and abovePOC and marketBull

if longCondition and strategy.position_size == 0
    strategy.entry("Long", strategy.long)

//====================================================
// 风控
//====================================================
atr = ta.atr(atrLen)
longStop = strategy.position_avg_price - atr * atrStopMult
strategy.exit("ATR Stop", "Long", stop=longStop)

//====================================================
// 主动出场
//====================================================
exitCondition = close < avwap or rs < 1.0
if exitCondition
    strategy.close("Long")

//====================================================
// 绘图
//====================================================
plot(avwap, color=color.orange, linewidth=2, title="AVWAP")
plot(poc,   color=color.blue,   linewidth=2, title="POC")
plotshape(longCondition,  title="Buy",  style=shape.triangleup,   location=location.belowbar, color=color.lime, size=size.small)
plotshape(exitCondition,  title="Sell", style=shape.triangledown, location=location.abovebar, color=color.red,  size=size.small)
